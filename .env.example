# ═══════════════════════════════════════════
# Пятница.ai — Конфигурация
# ═══════════════════════════════════════════

# General
DEBUG=false
LOG_LEVEL=INFO

# ─── LLM Провайдеры ──────────────────────
LLM__PRIMARY_PROVIDER=gigachat

# GigaChat (Сбер) — основной
# Получить credentials: https://developers.sber.ru/studio/workspaces
# 1. Создайте проект → 2. Получите Client ID и Client Secret
# 3. Закодируйте в base64: echo -n "client_id:client_secret" | base64
LLM__GIGACHAT_CREDENTIALS=
LLM__GIGACHAT_MODEL=GigaChat-2-Max
# Scope: GIGACHAT_API_PERS (физлицо) / GIGACHAT_API_B2B (бизнес) / GIGACHAT_API_CORP (корп)
LLM__GIGACHAT_SCOPE=GIGACHAT_API_PERS
LLM__GIGACHAT_VERIFY_SSL=false
# Для продакшена: скачайте сертификат Минцифры с Госуслуг и укажите путь
# LLM__GIGACHAT_CA_BUNDLE_FILE=/app/certs/russian_trusted_root_ca.cer
LLM__GIGACHAT_MAX_TOKENS=4096

# Claude (Anthropic) — опциональный fallback
# LLM__FALLBACK_PROVIDER=claude
# LLM__CLAUDE_API_KEY=sk-ant-...

# ─── Каналы связи ────────────────────────

# MAX messenger (основной)
# Получить токен: напишите @MasterBot в MAX → "Создать бота"
CHANNELS__MAX_BOT_TOKEN=
CHANNELS__MAX_USE_POLLING=true

# Telegram (fallback)
# CHANNELS__TELEGRAM_BOT_TOKEN=
# CHANNELS__TELEGRAM_USE_POLLING=true

# ─── Интеграции ──────────────────────────

# EasyRedmine
INTEGRATIONS__REDMINE_URL=
INTEGRATIONS__REDMINE_API_KEY=

# Битрикс24
# INTEGRATIONS__BITRIX_WEBHOOK_URL=https://your-company.bitrix24.ru/rest/1/xxxx/

# 1С
# INTEGRATIONS__ONEC_BASE_URL=
# INTEGRATIONS__ONEC_USERNAME=
# INTEGRATIONS__ONEC_PASSWORD=

# ─── Память ──────────────────────────────
MEMORY__DB_PATH=data/memory.db
MEMORY__MAX_CONTEXT_MESSAGES=20

# ─── Планировщик ─────────────────────────
SCHEDULER__HEARTBEAT_INTERVAL_MINUTES=5
SCHEDULER__ENABLED=true
